# =============================================================
# APPLICATION
# =============================================================
NODE_ENV=development
APP_PORT=3000
APP_HOST=localhost
APP_URL=http://localhost:3000

# =============================================================
# FRONTEND (Next.js)
# =============================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Ustriy System
FRONTEND_URL=http://localhost:3001
FRONTEND_PORT=3001

# =============================================================
# DATABASE (PostgreSQL)
# =============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=ustriy_db
DB_SSL=false

# TypeORM
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false
TYPEORM_MIGRATIONS_RUN=true

# =============================================================
# REDIS (reserved, not yet connected)
# =============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_change_this_in_production
REDIS_DB=0

# =============================================================
# JWT
# =============================================================
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_this_in_production
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================
# GOOGLE OAUTH
# =============================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# =============================================================
# TELEGRAM BOT (nestjs-telegraf)
# =============================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# University email domain for student verification (must start with @)
UNIVERSITY_EMAIL_DOMAIN=@kpi.ua

# =============================================================
# EMAIL (Nodemailer SMTP)
# =============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_email_app_password
MAIL_FROM=no-reply@yourdomain.com

# =============================================================
# CORS
# =============================================================
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# =============================================================
# RATE LIMITING (@nestjs/throttler)
# =============================================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# =============================================================
# SWAGGER
# =============================================================
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
SWAGGER_TITLE=Ustriy System API
SWAGGER_DESCRIPTION=REST API documentation
SWAGGER_VERSION=1.0
